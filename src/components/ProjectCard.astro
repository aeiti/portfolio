---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  href: string;
  title: string;
  discipline: 'concert' | 'theatre' | 'corporate-event';
  year: number;
  cover: ImageMetadata;
  coverKind?: 'photo' | 'plot';
}

const disciplineLabel: Record<Props['discipline'], string> = {
  concert: 'Concert',
  theatre: 'Theatre',
  'corporate-event': 'Corporate / Event',
};

const { href, title, discipline, year, cover, coverKind = 'photo' } = Astro.props;
---
<a class="card" href={href}>
  <div class={`art kind-${coverKind}`}>
    <Image
      src={cover}
      alt={`Cover for ${title}`}
      widths={[480, 720, 960, 1280]}
      sizes="(min-width: 900px) 33vw, (min-width: 600px) 50vw, 100vw"
      loading="lazy"
    />
  </div>
  <div class="meta">
    <span class="tag">{disciplineLabel[discipline]} &middot; {year}</span>
    <h3>{title}</h3>
  </div>
</a>

<style>
  .card {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .art {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--bg-elev);
    border: 1px solid var(--border);
  }
  .art :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms ease;
  }
  .card:hover .art :global(img) {
    transform: scale(1.02);
  }
  .art.kind-plot :global(img) {
    object-fit: contain;
    background: var(--bg-elev);
  }
  .meta {
    padding-top: 0.9rem;
  }
  .meta h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    margin: 0.25rem 0 0;
  }
</style>
