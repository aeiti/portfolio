---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  href: string;
  title: string;
  discipline: 'concert' | 'theatre' | 'corporate-event';
  year: number;
  cover?: ImageMetadata;
  coverKind?: 'photo' | 'plot';
}

const disciplineLabel: Record<Props['discipline'], string> = {
  concert: 'Concert',
  theatre: 'Theatre',
  'corporate-event': 'Corporate / Event',
};

const { href, title, discipline, year, cover, coverKind = 'photo' } = Astro.props;
---
<a class="card" href={href}>
  {cover ? (
    <div class={`art kind-${coverKind}`}>
      <Image
        src={cover}
        alt={`Cover for ${title}`}
        widths={[480, 720, 960, 1280]}
        sizes="(min-width: 900px) 33vw, (min-width: 600px) 50vw, 100vw"
        loading="lazy"
      />
    </div>
  ) : (
    <div class={`art kind-titlecard discipline-${discipline}`} aria-hidden="true">
      <span class="tc-tag">{disciplineLabel[discipline]} &middot; {year}</span>
      <span class="tc-title">{title}</span>
    </div>
  )}
  <div class="meta">
    <span class="tag">{disciplineLabel[discipline]} &middot; {year}</span>
    <h3>{title}</h3>
  </div>
</a>

<style>
  .card {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .art {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--bg-elev);
    border: 1px solid var(--border);
  }
  .art :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms ease;
  }
  .card:hover .art :global(img) {
    transform: scale(1.02);
  }
  .art.kind-plot :global(img) {
    object-fit: contain;
    background: var(--bg-elev);
  }

  .art.kind-titlecard {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 1.25rem 1.25rem 1.5rem;
    background:
      radial-gradient(120% 80% at 50% 100%, rgba(255, 180, 83, 0.08), transparent 60%),
      var(--bg-elev);
    transition: border-color 200ms ease;
  }
  .art.kind-titlecard.discipline-theatre {
    background:
      radial-gradient(120% 80% at 50% 100%, rgba(255, 180, 83, 0.12), transparent 60%),
      var(--bg-elev);
  }
  .art.kind-titlecard.discipline-concert {
    background:
      radial-gradient(120% 80% at 50% 100%, rgba(120, 180, 255, 0.10), transparent 60%),
      var(--bg-elev);
  }
  .art.kind-titlecard.discipline-corporate-event {
    background:
      radial-gradient(120% 80% at 50% 100%, rgba(180, 180, 180, 0.08), transparent 60%),
      var(--bg-elev);
  }
  .card:hover .art.kind-titlecard {
    border-color: var(--border-strong);
  }
  .tc-tag {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }
  .tc-title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.6vw, 2rem);
    line-height: 1.15;
    color: var(--fg);
    letter-spacing: -0.01em;
  }

  .meta {
    padding-top: 0.9rem;
  }
  .meta h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    margin: 0.25rem 0 0;
  }
</style>
