---
import Base from '../layouts/Base.astro';
const email = 'adam@thomasavl.com';
---
<Base
  title="Contact"
  description="Get in touch with Adam Manning for lighting design, programming, and associate work."
>
  <section class="container contact">
    <p class="eyebrow">Contact</p>
    <h1>Let's talk about your show.</h1>
    <p class="lede prose">
      Open for design, programming, and associate work across the U.S.
      The fastest way to reach me is email.
    </p>

    <a class="email" href={`mailto:${email}`}>{email}</a>

    <p class="form-note prose">
      A contact form is coming in the next update. For now, please use
      the email link above — include show dates, venue, and a one-line
      description of the project.
    </p>
  </section>
</Base>

<style>
  .contact { padding-block: 4rem 5rem; }
  .lede {
    color: var(--fg-muted);
    font-size: 1.15rem;
    margin-bottom: 3rem;
  }
  .email {
    display: inline-block;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    text-decoration: none;
    border-bottom: 1px solid var(--border-strong);
    padding-bottom: 0.2em;
    transition: border-color 120ms ease, color 120ms ease;
  }
  .email:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .form-note {
    margin-top: 3rem;
    color: var(--fg-muted);
    font-size: 0.95rem;
  }
</style>
