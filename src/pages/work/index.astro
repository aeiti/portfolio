---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const all = await getCollection('projects', ({ data }) => !data.draft);
const sorted = all.sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);

function slugOf(entry: (typeof sorted)[number]) {
  return entry.id.replace(/\/index$/, '');
}
---
<Base
  title="Work"
  description="Selected lighting design projects — concert, theatre, and corporate events."
>
  <section class="container intro">
    <p class="eyebrow">Work</p>
    <h1>Selected projects</h1>
    <p class="lede prose">
      A working portfolio. More projects are being added as production
      photos, plots, and write-ups come together.
    </p>
  </section>

  <section class="container grid-wrap">
    <div class="grid">
      {sorted.map((entry) => (
        <ProjectCard
          href={`${base}/work/${slugOf(entry)}/`}
          title={entry.data.title}
          discipline={entry.data.discipline}
          year={entry.data.year}
          cover={entry.data.cover}
          coverKind={entry.data.coverKind}
        />
      ))}
    </div>
  </section>
</Base>

<style>
  .intro {
    padding-top: 3rem;
    padding-bottom: 2rem;
  }
  .lede {
    color: var(--fg-muted);
    font-size: 1.1rem;
  }
  .grid-wrap {
    padding-bottom: 4rem;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem 2rem;
  }
  @media (max-width: 900px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
